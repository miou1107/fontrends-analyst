{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["meta", "title", "chapters"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["brand", "period"],
      "properties": {
        "brand": { "type": "string", "minLength": 1 },
        "competitor": { "type": "string" },
        "period": { "type": "string" },
        "purpose": { "type": "string" },
        "venue": { "type": "string" },
        "generated_at": { "type": "string" }
      }
    },
    "title": { "type": "string", "minLength": 1 },
    "executive_summary": { "type": "string" },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "paragraphs"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "paragraphs": { "type": "array", "items": { "type": "string" } },
          "data_table": {
            "type": "object",
            "required": ["headers", "rows"],
            "properties": {
              "headers": { "type": "array", "items": { "type": "string" } },
              "rows": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } }
            }
          },
          "insight": { "type": "string" },
          "so_what": { "type": "string" },
          "action_link": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "who", "what", "when", "kpi"],
        "properties": {
          "priority": { "type": "string" },
          "who": { "type": "string" },
          "what": { "type": "string" },
          "when": { "type": "string" },
          "kpi": { "type": "string" }
        }
      }
    }
  }
}
