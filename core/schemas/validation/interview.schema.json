{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["brand", "purpose"],
  "properties": {
    "brand": { "type": "string", "minLength": 1 },
    "competitor": { "type": "string" },
    "purpose": { "type": "string", "enum": ["sell-venue", "brand-review", "competitive-analysis", "market-entry", "prove-partnership-value"] },
    "venue": { "type": "string" },
    "audience": { "type": "string" },
    "objective": { "type": "string" },
    "sources": {
      "oneOf": [
        { "type": "array", "items": { "type": "string" } },
        {
          "type": "object",
          "properties": {
            "looker_studio": { "type": "string" },
            "mysql": { "type": "boolean" },
            "ga4": { "type": "string" },
            "gsc": { "type": "string" },
            "google_trends": { "type": "boolean" },
            "dataforseo": { "type": "boolean" }
          }
        }
      ]
    },
    "dashboard_url": { "type": "string" },
    "period": { "type": "string" },
    "output_formats": { "type": "array", "items": { "type": "string", "enum": ["pptx", "gslides", "gdocs"] } },
    "key_angles": { "type": "array", "items": { "type": "string" } },
    "tone": { "type": "string" },
    "notes": { "type": "string" },
    "language": { "type": "string", "default": "zh-TW" }
  }
}
